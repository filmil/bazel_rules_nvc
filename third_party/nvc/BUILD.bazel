package(default_visibility = ["//visibility:public"])

filegroup(
    name = "nvc_repo",
    srcs = ["@nvc_deb//:all_files"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "compiler",
    srcs = ["@nvc_deb//:usr/bin/nvc"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "deps",
    srcs = select({
        "//internal/config:ubuntu_24_04": [
            "@deps_24_04//:files",
        ],
        "//conditions:default": [
            "@deps_22_04//:files",
        ],
    }),
    visibility = ["//visibility:public"],
)

