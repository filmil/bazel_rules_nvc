load(
    "//build/nvc:rules.bzl",
    "nvc_vhdl_elaborate",
    "nvc_vhdl_library",
    "nvc_vhdl_run",
)

nvc_vhdl_library(
    name = "work",
    srcs = [
        "test.vhdl",
    ],
    entities = ["hello_world"],
)

nvc_vhdl_elaborate(
    name = "hello_world",
    library = ":work",
)

nvc_vhdl_run(
    name = "sim",
    entity = ":hello_world",
)
