load("//build/nvc:rules.bzl", "nvc_vhdl_elaborate", "nvc_vhdl_library", "nvc_vhdl_run")

nvc_vhdl_library(
    name = "sim",
    srcs = [
        "clkgen.vhdl",
        "resetgen.vhdl",
    ],
)

nvc_vhdl_library(
    name = "test",
    srcs = [
        "clkgen_test.vhdl",
    ],
    deps = [":sim"],
)

nvc_vhdl_elaborate(
    name = "tb",
    library = ":test",
)

nvc_vhdl_run(
    name = "run",
    entity = ":tb",
)
